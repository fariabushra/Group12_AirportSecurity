<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.airportsecurity.Ahsan.CommandingOfficer.DashboardController"
            prefHeight="400.0" prefWidth="600.0">

    <Label text="Flight Management System Dashboard"
           layoutX="120" layoutY="20"
           style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <Button text="Manage Flights"
            layoutX="250" layoutY="80"
            prefWidth="200"
            onAction="#goManageFlights"/>

    <Button text="Assign Staff"
            layoutX="250" layoutY="130"
            prefWidth="200"
            onAction="#goAssignStaff"/>

    <Button text="Approve / Cancel Flights"
            layoutX="250" layoutY="180"
            prefWidth="200"
            onAction="#goApproveCancel"/>

    <Button text="View Flight Details"
            layoutX="250" layoutY="230"
            prefWidth="200"
            onAction="#goViewDetails"/>

    <Button text="Announcements"
            layoutX="250" layoutY="280"
            prefWidth="200"
            onAction="#goAnnouncements"/>

    <Button text="Monitor Status"
            layoutX="250" layoutY="330"
            prefWidth="200"
            onAction="#goMonitorStatus"/>

    <Button text="Emergency Alerts"
            layoutX="250" layoutY="380"
            prefWidth="200"
            onAction="#goEmergency"/>

</AnchorPane>