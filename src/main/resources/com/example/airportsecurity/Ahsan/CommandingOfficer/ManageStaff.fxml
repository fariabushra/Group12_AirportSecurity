      <TextField fx:id="roleField" layoutX="76.0" layoutY="120.0" />
      <Text layoutX="27.0" layoutY="94.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Name  :" wrappingWidth="53.58203125" />
      <Text layoutX="33.0" layoutY="137.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Role  :" wrappingWidth="42.9921875" />
      <TableView fx:id="staffTable" layoutX="36.0" layoutY="194.0" prefHeight="200.0" prefWidth="200.0">
