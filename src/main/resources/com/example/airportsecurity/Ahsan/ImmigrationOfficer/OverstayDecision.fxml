<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.airportsecurity.Ahsan.ImmigrationOfficer.OverstayDecisionController"
            prefHeight="400.0" prefWidth="600.0">
    <Label text="Overstay Decision System"
           layoutX="20" layoutY="10"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TextField fx:id="searchField"
               layoutX="20" layoutY="50"
               prefWidth="200"
               promptText="Enter Passport No"/>

    <Button text="Search"
            layoutX="240" layoutY="50"
            onAction="#search"/>

    <Button text="Load Data"
            layoutX="320" layoutY="50"
            onAction="#loadData"/>

    <Button text="Approve"
            layoutX="420" layoutY="50"
            onAction="#approve"/>

    <Button text="Reject"
            layoutX="520" layoutY="50"
            onAction="#reject"/>

    <Button text="Back"
            layoutX="620" layoutY="50"
            onAction="#back"/>

    <TableView fx:id="table"
               layoutX="20" layoutY="100"
               prefWidth="750" prefHeight="350">

        <columns>

            <TableColumn fx:id="nameCol" text="Name" prefWidth="150"/>
            <TableColumn fx:id="passportCol" text="Passport" prefWidth="150"/>
            <TableColumn fx:id="entryCol" text="Entry Date" prefWidth="120"/>
            <TableColumn fx:id="allowedCol" text="Allowed Days" prefWidth="120"/>
            <TableColumn fx:id="currentCol" text="Current Date" prefWidth="120"/>
            <TableColumn fx:id="statusCol" text="Status" prefWidth="90"/>

        </columns>

    </TableView>

</AnchorPane>


