<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.airportsecurity.Ahsan.ImmigrationOfficer.Dashboard2Controller"
            prefHeight="400.0" prefWidth="600.0">

    <Label text="Immigration Officer Dashboard"
           layoutX="200" layoutY="20"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <Button text="Check Passport"
            layoutX="50" layoutY="80"
            prefWidth="200"
            onAction="#openPassport"/>

    <Button text="Entry Permission"
            layoutX="50" layoutY="130"
            prefWidth="200"
            onAction="#openEntry"/>

    <Button text="Exit Permission"
            layoutX="50" layoutY="180"
            prefWidth="200"
            onAction="#openExit"/>

    <Button text="Renew Visa"
            layoutX="50" layoutY="230"
            prefWidth="200"
            onAction="#openRenew"/>

    <Button text="Overstay Check"
            layoutX="50" layoutY="280"
            prefWidth="200"
            onAction="#openOverstay"/>

    <Button text="Overstay Management (BIN)"
            layoutX="350" layoutY="130"
            prefWidth="250"
            onAction="#openOverstayManage"/>

    <Button text="Overstay Decision System"
            layoutX="350" layoutY="180"
            prefWidth="250"
            onAction="#openDecision"/>

    <Button text="Exit App"
            layoutX="350" layoutY="280"
            prefWidth="250"
            onAction="#exitApp"/>

</AnchorPane>
