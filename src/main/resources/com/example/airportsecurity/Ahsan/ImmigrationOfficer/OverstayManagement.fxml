<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.airportsecurity.Ahsan.ImmigrationOfficer.OverstayManagementController"
            prefHeight="400.0" prefWidth="600.0">

    <Label text="Overstay Management"
           layoutX="20" layoutY="10"/>

    <TextField fx:id="nameField" layoutX="20" layoutY="50" promptText="Name"/>
    <TextField fx:id="passportField" layoutX="20" layoutY="90" promptText="Passport No"/>
    <TextField fx:id="entryField" layoutX="20" layoutY="130" promptText="Entry Date"/>
    <TextField fx:id="allowedField" layoutX="20" layoutY="170" promptText="Allowed Days"/>
    <TextField fx:id="currentField" layoutX="20" layoutY="210" promptText="Current Date"/>

    <Button text="Add" layoutX="260" layoutY="50" onAction="#add"/>
    <Button text="Detect" layoutX="260" layoutY="90" onAction="#detect"/>
    <Button text="Save BIN" layoutX="260" layoutY="130" onAction="#save"/>
    <Button text="Load BIN" layoutX="260" layoutY="170" onAction="#load"/>
    <Button text="Back" layoutX="20" layoutY="430" onAction="#back"/>

    <TextArea fx:id="outputArea"
              layoutX="20" layoutY="250"
              prefWidth="650" prefHeight="150"/>

</AnchorPane>