<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SecurityOfficerController">
    <children>
        <VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="200.0" spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <children>
                <Label text="Security Panel" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <Button mnemonicParsing="false" onAction="#logoutOnAction" prefWidth="150.0" style="-fx-background-color: #e74c3c;" text="Logout" textFill="WHITE" />
            </children>
        </VBox>
        <VBox layoutX="250.0" layoutY="80.0" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#goal1OnAction" prefWidth="350.0" text="Goal 1: Incident Reporting" />
                <Button mnemonicParsing="false" onAction="#goal2OnAction" prefWidth="350.0" text="Goal 2: Lost and Found" />
                <Button mnemonicParsing="false" onAction="#goal3OnAction" prefWidth="350.0" text="Goal 3: Patrol Logs" />
                <Button mnemonicParsing="false" onAction="#goal4OnAction" prefWidth="350.0" text="Goal 4: Equipment Maintenance Request" />
                <Button mnemonicParsing="false" onAction="#goal5OnAction" prefWidth="350.0" text="Goal 5: Register New Visitor" />
                <Button mnemonicParsing="false" onAction="#goal6OnAction" prefWidth="350.0" text="Goal 6: Trigger Emergency Alert" />
                <Button mnemonicParsing="false" onAction="#goal7OnAction" prefWidth="350.0" text="Goal 7: Baggage Inspection Log" />
                <Button mnemonicParsing="false" onAction="#goal8OnAction" prefWidth="350.0" text="Goal 8: End of Shift Handover" />
            </children>
        </VBox>
    </children>
</AnchorPane>
