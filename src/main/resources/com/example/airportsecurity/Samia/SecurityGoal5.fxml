<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SecurityGoal5Controller">
    <children>
        <Label layoutX="30.0" layoutY="30.0" text="Goal 5: Register New Visitor">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <VBox layoutX="30.0" layoutY="100.0" spacing="15.0">
            <children>
                <TextField fx:id="visitorNameField" prefWidth="350.0" promptText="Visitor Full Name" />
                <TextField fx:id="idField" prefWidth="350.0" promptText="Passport/NID Number" />
                <TextField fx:id="purposeField" prefWidth="350.0" promptText="Purpose of Entry" />
                <Button onAction="#registerVisitorOnAction" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #8e44ad; -fx-text-fill: white;" text="Register Entry" />
            </children>
        </VBox>
        <Button layoutX="520.0" layoutY="350.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>