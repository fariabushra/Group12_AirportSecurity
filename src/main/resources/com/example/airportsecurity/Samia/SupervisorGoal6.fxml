<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SupervisorGoal6Controller">
    <children>
        <Label layoutX="30.0" layoutY="20.0" text="Goal 6: Emergency Incident History">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <TableView fx:id="alertTable" layoutX="30.0" layoutY="70.0" prefHeight="300.0" prefWidth="640.0">
            <columns>
                <TableColumn fx:id="timeCol" prefWidth="150.0" text="Timestamp" />
                <TableColumn fx:id="typeCol" prefWidth="140.0" text="Type" />
                <TableColumn fx:id="locCol" prefWidth="200.0" text="Location" />
                <TableColumn fx:id="sevCol" prefWidth="148.0" text="Severity" />
            </columns>
        </TableView>
        <Button layoutX="620.0" layoutY="390.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>