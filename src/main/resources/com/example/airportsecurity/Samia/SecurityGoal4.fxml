<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SecurityGoal4Controller">
    <children>
        <Label layoutX="30.0" layoutY="30.0" text="Goal 4: Equipment Maintenance Request">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <VBox layoutX="30.0" layoutY="80.0" spacing="15.0">
            <children>
                <TextField fx:id="equipNameField" prefWidth="350.0" promptText="Equipment Name (e.g. Scanner 04)" />
                <TextField fx:id="serialField" prefWidth="350.0" promptText="Serial Number" />
                <ComboBox fx:id="conditionCombo" prefWidth="350.0" promptText="Select Condition" />
                <Button onAction="#submitRequestOnAction" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Submit Request" />
            </children>
        </VBox>
        <Button layoutX="520.0" layoutY="350.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>