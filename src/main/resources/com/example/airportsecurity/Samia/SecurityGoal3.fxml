<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SecurityGoal3Controller">
    <children>
        <Label layoutX="30.0" layoutY="30.0" text="Goal 3: Submit Patrol Log">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <VBox layoutX="30.0" layoutY="100.0" spacing="20.0">
            <children>
                <ComboBox fx:id="zoneComboBox" prefWidth="250.0" promptText="Select Zone" />
                <ComboBox fx:id="statusComboBox" prefWidth="250.0" promptText="Select Status" />
                <Button onAction="#submitLogOnAction" prefWidth="150.0" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="Log Patrol" />
            </children>
        </VBox>
        <Button layoutX="520.0" layoutY="350.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>