<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="489.0" prefWidth="684.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Faria.PatientStatusUpdateController">
   <children>
      <Label layoutX="94.0" layoutY="59.0" text="Patient ID:" />
      <TextField fx:id="idSearchField" layoutX="160.0" layoutY="55.0" />
      <Button layoutX="245.0" layoutY="112.0" mnemonicParsing="false" onAction="#searchButton" text="Search Patient">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Label fx:id="systemMessageLabel" layoutX="376.0" layoutY="138.0" prefHeight="26.0" prefWidth="242.0" style="-fx-background-color: yellow;" />
      <Label layoutX="66.0" layoutY="248.0" text="Display Status:" />
      <Label fx:id="displayStatusLabel" layoutX="156.0" layoutY="235.0" prefHeight="44.0" prefWidth="275.0" style="-fx-border-color: blue;" />
      <CheckBox fx:id="firstAidCheck" layoutX="84.0" layoutY="181.0" mnemonicParsing="false" text="First Aid Done" />
      <ComboBox fx:id="statusCombo" layoutX="160.0" layoutY="314.0" prefHeight="34.0" prefWidth="250.0" promptText="Update Patient Status" />
      <Button layoutX="324.0" layoutY="376.0" mnemonicParsing="false" onAction="#updateButton" prefHeight="34.0" prefWidth="78.0" text="Update">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
      <Button layoutX="571.0" layoutY="449.0" mnemonicParsing="false" onAction="#dashboardButton" text="&lt;&lt;Dashboard">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
