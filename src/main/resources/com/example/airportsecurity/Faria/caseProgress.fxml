<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Faria.CaseProgressController">
   <children>
      <Label layoutX="73.0" layoutY="51.0" text="Patient ID:" />
      <TextField fx:id="idInput" layoutX="143.0" layoutY="47.0" />
      <Button layoutX="192.0" layoutY="109.0" mnemonicParsing="false" onAction="#searchCaseButton" text="Search Case">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
      <Label fx:id="caseInfoLabel" layoutX="335.0" layoutY="108.0" prefHeight="26.0" prefWidth="242.0" style="-fx-background-color: yellow;" />
      <ComboBox fx:id="caseProgressCombo" layoutX="90.0" layoutY="188.0" prefHeight="26.0" prefWidth="190.0" promptText="Case Progress" />
      <Button layoutX="192.0" layoutY="255.0" mnemonicParsing="false" onAction="#updateProgressButton" text="Update">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
      <Label fx:id="statusLabel" layoutX="293.0" layoutY="256.0" prefHeight="26.0" prefWidth="242.0" style="-fx-background-color: yellow;" />
      <Button layoutX="482.0" layoutY="356.0" mnemonicParsing="false" onAction="#dashboardButton" text="&lt;&lt;Dashboard">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
