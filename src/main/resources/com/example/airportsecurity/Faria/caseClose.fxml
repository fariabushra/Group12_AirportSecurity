<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Faria.CaseCloseController">
   <children>
      <Label layoutX="72.0" layoutY="60.0" text="Patient ID:" />
      <TextField fx:id="idInput" layoutX="144.0" layoutY="56.0" />
      <Button layoutX="197.0" layoutY="122.0" mnemonicParsing="false" onAction="#searchForCase" text="Search Case">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
      <Label fx:id="caseDetailsLabel" layoutX="314.0" layoutY="124.0" prefHeight="26.0" prefWidth="258.0" style="-fx-background-color: yellow;" />
      <ComboBox fx:id="finalStatusCombo" layoutX="83.0" layoutY="187.0" prefWidth="150.0" promptText="Final Case Status" />
      <Button layoutX="197.0" layoutY="254.0" mnemonicParsing="false" onAction="#closeCaseButton" text="Close Case">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
      <Label fx:id="confirmationLabel" layoutX="314.0" layoutY="255.0" prefHeight="26.0" prefWidth="258.0" style="-fx-background-color: yellow;" />
      <Button layoutX="468.0" layoutY="356.0" mnemonicParsing="false" onAction="#dashboardButton" text="&lt;&lt;Dashboard">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
