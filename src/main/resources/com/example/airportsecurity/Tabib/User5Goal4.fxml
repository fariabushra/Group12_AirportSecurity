<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Tabib.U5G4Controller">

    <children>
        <Label layoutX="220.0" layoutY="20.0" text="Radio / Unit Panel">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <Label layoutX="46.0" layoutY="57.0" text="Unit List">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <TableView fx:id="unitTableView" layoutX="46.0" layoutY="96.0" prefHeight="180.0" prefWidth="250.0">
            <columns>
                <TableColumn fx:id="unitIdColumn" prefWidth="70.0" text="ID" />
                <TableColumn fx:id="unitNameColumn" prefWidth="178.0" text="Unit Name" />
            </columns>
        </TableView>

        <Label layoutX="340.0" layoutY="70.0" text="Instruction Message">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <TextArea fx:id="messageTextArea" layoutX="340.0" layoutY="100.0" prefHeight="180.0" prefWidth="300.0" promptText="Write message here..." wrapText="true" />

        <Button fx:id="sendButton" layoutX="340.0" layoutY="300.0" mnemonicParsing="false" onAction="#sendButton" prefHeight="35.0" prefWidth="100.0" text="Send" />

        <Label fx:id="statusLabel" layoutX="460.0" layoutY="307.0" prefHeight="20.0" prefWidth="180.0" />

        <Button layoutX="586.0" layoutY="350.0" mnemonicParsing="false" onAction="#backButton" prefHeight="35.0" prefWidth="100.0" text="Back" />
    </children>

</AnchorPane>
