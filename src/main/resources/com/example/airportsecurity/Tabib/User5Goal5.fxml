<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Tabib.U5G5Controller">

    <children>
        <Label layoutX="298.0" layoutY="20.0" prefHeight="35.0" prefWidth="170.0" text="    Incident Log ">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <TableView fx:id="incidentTableView" layoutX="30.0" layoutY="80.0" prefHeight="180.0" prefWidth="740.0">
            <columns>
                <TableColumn fx:id="incidentIdColumn" prefWidth="120.0" text="Incident ID" />
                <TableColumn fx:id="zoneColumn" prefWidth="180.0" text="Zone" />
                <TableColumn fx:id="priorityColumn" prefWidth="180.0" text="Priority" />
                <TableColumn fx:id="statusColumn" prefWidth="258.0" text="Status" />
            </columns>
        </TableView>

        <Button fx:id="viewTimelineButton" layoutX="100.0" layoutY="280.0" mnemonicParsing="false" onAction="#viewTimelineButton" prefHeight="35.0" prefWidth="140.0" text="View Timeline" />

        <Button fx:id="addUpdateButton" layoutX="320.0" layoutY="280.0" mnemonicParsing="false" onAction="#addUpdateButton" prefHeight="35.0" prefWidth="140.0" text="Add Update" />

        <Button fx:id="saveUpdateButton" layoutX="540.0" layoutY="280.0" mnemonicParsing="false" onAction="#saveUpdateButton" prefHeight="35.0" prefWidth="140.0" text="Save Update" />

        <Label layoutX="30.0" layoutY="340.0" text="Timeline / Status Details">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <TextArea fx:id="timelineTextArea" layoutX="30.0" layoutY="370.0" prefHeight="80.0" prefWidth="350.0" wrapText="true" />

        <Label layoutX="420.0" layoutY="340.0" text="Add Update Note">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <TextArea fx:id="updateTextArea" layoutX="420.0" layoutY="370.0" prefHeight="80.0" prefWidth="350.0" promptText="Write update note here..." wrapText="true" />

        <Label fx:id="messageLabel" layoutX="30.0" layoutY="465.0" prefHeight="20.0" prefWidth="500.0" text="" />

        <Button fx:id="backButton" layoutX="650.0" layoutY="460.0" mnemonicParsing="false" onAction="#backButton" prefHeight="30.0" prefWidth="100.0" text="Back" />
    </children>

</AnchorPane>
