<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Tabib.U6G4Controller">

    <children>

        <Text fill="#1f4e79" layoutX="302.0" layoutY="40.0" strokeType="OUTSIDE" strokeWidth="0.0" text="View &amp; Filter Audit Logs">
            <font>
                <Font size="24.0" />
            </font>
        </Text>

        <Text fill="#2f66b3" layoutX="25.0" layoutY="75.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Filter Options">
            <font>
                <Font size="20.0" />
            </font>
        </Text>

        <Text layoutX="25.0" layoutY="125.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Log Type:" />
        <ComboBox fx:id="logTypeComboBox" layoutX="110.0" layoutY="103.0" prefHeight="30.0" prefWidth="220.0" promptText="Select log type" />

        <Text layoutX="370.0" layoutY="125.0" strokeType="OUTSIDE" strokeWidth="0.0" text="From Date:" />
        <DatePicker fx:id="fromDatePicker" layoutX="455.0" layoutY="103.0" prefHeight="30.0" prefWidth="180.0" />

        <Text layoutX="670.0" layoutY="125.0" strokeType="OUTSIDE" strokeWidth="0.0" text="To Date:" />
        <DatePicker fx:id="toDatePicker" layoutX="740.0" layoutY="103.0" prefHeight="30.0" prefWidth="180.0" />

        <Button layoutX="110.0" layoutY="155.0" mnemonicParsing="false" onAction="#applyFilterButton" prefHeight="32.0" prefWidth="120.0" text="Apply Filter" />
        <Button layoutX="245.0" layoutY="155.0" mnemonicParsing="false" onAction="#exportLogsButton" prefHeight="32.0" prefWidth="120.0" text="Export Logs" />
        <Button layoutX="380.0" layoutY="155.0" mnemonicParsing="false" onAction="#clearButton" prefHeight="32.0" prefWidth="100.0" text="Clear" />
        <Button layoutX="870.0" layoutY="604.0" mnemonicParsing="false" onAction="#backButton" prefHeight="32.0" prefWidth="100.0" text="Back" />

        <Label fx:id="statusLabel" layoutX="620.0" layoutY="161.0" prefHeight="20.0" prefWidth="320.0" text="Status message" visible="false" />

        <Text fill="#2f66b3" layoutX="25.0" layoutY="235.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Audit Log Records">
            <font>
                <Font size="20.0" />
            </font>
        </Text>

        <TableView fx:id="logTableView" layoutX="25.0" layoutY="255.0" prefHeight="340.0" prefWidth="950.0">
            <columns>
                <TableColumn fx:id="timeColumn" prefWidth="180.0" text="Time" />
                <TableColumn fx:id="userColumn" prefWidth="170.0" text="User" />
                <TableColumn fx:id="actionColumn" prefWidth="220.0" text="Action" />
                <TableColumn fx:id="moduleColumn" prefWidth="190.0" text="Module" />
                <TableColumn fx:id="statusColumn" prefWidth="185.0" text="Status" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
