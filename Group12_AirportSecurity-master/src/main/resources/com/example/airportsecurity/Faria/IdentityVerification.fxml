         </font>
      </Button>
      <TableView fx:id="personTable" layoutX="1.0" layoutY="173.0" prefHeight="200.0" prefWidth="914.0">
         <columns>
            <TableColumn fx:id="nameCol" prefWidth="83.99999809265137" text="Name" />
            <TableColumn fx:id="nidCol" prefWidth="75.9999771118164" text="NID No" />
            <TableColumn fx:id="passportCol" prefWidth="107.20001220703125" text="Passport No" />
            <TableColumn fx:id="phoneNoCol" prefWidth="114.39996337890625" text="Phone No" />
            <TableColumn fx:id="emailCol" prefWidth="136.80001831054688" text="Email" />
