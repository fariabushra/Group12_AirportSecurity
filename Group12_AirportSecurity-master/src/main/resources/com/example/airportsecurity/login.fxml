<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.LoginController">
   <children>
      <Label layoutX="189.0" layoutY="43.0" prefHeight="70.0" prefWidth="178.0" text="    Login Page">
         <font>
            <Font size="25.0" />
         </font>
      </Label>
      <Label layoutX="80.0" layoutY="134.0" text="Username:" />
      <Label layoutX="80.0" layoutY="182.0" text="Password:" />
      <TextField fx:id="usernameTextField" layoutX="172.0" layoutY="130.0" />
      <PasswordField fx:id="passwordTextField" layoutX="173.0" layoutY="178.0" />
      <Button layoutX="252.0" layoutY="235.0" mnemonicParsing="false" onAction="#loginOnAction" prefHeight="38.0" prefWidth="67.0" text="Login" />
      <Label layoutX="133.0" layoutY="329.0" text="Don't have an account?">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <Button layoutX="316.0" layoutY="321.0" mnemonicParsing="false" onAction="#signUpOnAction" prefHeight="38.0" prefWidth="78.0" text="Sign Up" />
   </children>
</AnchorPane>
