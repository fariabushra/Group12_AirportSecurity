<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SupervisorGoal1Controller">
    <children>
        <Label layoutX="30.0" layoutY="20.0" text="Supervisor: Review Incident Reports">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>

        <TableView fx:id="incidentTable" layoutX="30.0" layoutY="70.0" prefHeight="300.0" prefWidth="590.0">
            <columns>
                <TableColumn fx:id="titleColumn" prefWidth="150.0" text="Title" />
                <TableColumn fx:id="descColumn" prefWidth="280.0" text="Description" />
                <TableColumn fx:id="dateColumn" prefWidth="158.0" text="Date/Time" />
            </columns>
        </TableView>

        <Button layoutX="30.0" layoutY="390.0" onAction="#approveSelectedOnAction" style="-fx-background-color: green; -fx-text-fill: white;" text="Approve Selected" />
        <Button layoutX="570.0" layoutY="390.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>
