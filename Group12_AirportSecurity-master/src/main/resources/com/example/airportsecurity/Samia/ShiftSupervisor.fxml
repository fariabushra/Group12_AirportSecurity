<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.ShiftSupervisorController">
    <children>
        <VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="200.0" spacing="15.0" style="-fx-background-color: #34495e; -fx-padding: 20;">
            <children>
                <Label text="Supervisor Panel" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <Button mnemonicParsing="false" onAction="#backToLogin" prefWidth="150.0" style="-fx-background-color: #e74c3c;" text="Logout" textFill="WHITE" />
            </children>
        </VBox>
        <VBox layoutX="250.0" layoutY="80.0" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#supGoal1OnAction" prefWidth="350.0" text="Goal 1: Approve Incident Reports" />
                <Button mnemonicParsing="false" onAction="#supGoal2OnAction" prefWidth="350.0" text="Goal 2: Lost and Found Inventory" />
                <Button mnemonicParsing="false" onAction="#supGoal3OnAction" prefWidth="350.0" text="Goal 3: Review Patrol History" />
                <Button mnemonicParsing="false" onAction="#supGoal4OnAction" prefWidth="350.0" text="Goal 4: Security Equipment Audit" />
                <Button mnemonicParsing="false" onAction="#supGoal5OnAction" prefWidth="350.0" text="Goal 5: Security Visitor Logbook" />
                <Button mnemonicParsing="false" onAction="#supGoal6OnAction" prefWidth="350.0" text="Goal 6: Emergency Incident History" />
                <Button mnemonicParsing="false" onAction="#supGoal7OnAction" prefWidth="350.0" text="Goal 7: Baggage Inspection Audit" />
                <Button mnemonicParsing="false" onAction="#supGoal8OnAction" prefWidth="350.0" text="Goal 8: Staff Shift Handover Audit" />
            </children>
        </VBox>
    </children>
</AnchorPane>
