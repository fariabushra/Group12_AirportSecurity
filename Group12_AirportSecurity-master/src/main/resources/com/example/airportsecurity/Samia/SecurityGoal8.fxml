<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SecurityGoal8Controller">
    <children>
        <Label layoutX="30.0" layoutY="30.0" text="Goal 8: End of Shift Handover">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <VBox layoutX="30.0" layoutY="80.0" spacing="15.0">
            <children>
                <TextField fx:id="nameField" prefWidth="400.0" promptText="Officer Name" />
                <ComboBox fx:id="shiftCombo" prefWidth="400.0" promptText="Select Shift Type" />
                <TextArea fx:id="notesArea" prefHeight="150.0" prefWidth="400.0" promptText="Key observations, pending tasks, or incidents..." />
                <Button onAction="#submitHandoverOnAction" prefWidth="150.0" style="-fx-background-color: #16a085; -fx-text-fill: white;" text="Submit Handover" />
            </children>
        </VBox>
        <Button layoutX="520.0" layoutY="400.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>