<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SupervisorGoal5Controller">
    <children>
        <Label layoutX="30.0" layoutY="20.0" text="Goal 5: Security Visitor Logbook">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <TableView fx:id="visitorTable" layoutX="30.0" layoutY="70.0" prefHeight="300.0" prefWidth="590.0">
            <columns>
                <TableColumn fx:id="timeCol" prefWidth="150.0" text="Entry Time" />
                <TableColumn fx:id="nameCol" prefWidth="150.0" text="Name" />
                <TableColumn fx:id="purposeCol" prefWidth="288.0" text="Purpose" />
            </columns>
        </TableView>
        <Button layoutX="570.0" layoutY="390.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>