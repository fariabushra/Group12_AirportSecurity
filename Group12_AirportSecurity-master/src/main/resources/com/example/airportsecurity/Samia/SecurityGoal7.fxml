<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SecurityGoal7Controller">
    <children>
        <Label layoutX="30.0" layoutY="30.0" text="Goal 7: Baggage Inspection Log">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <VBox layoutX="30.0" layoutY="80.0" spacing="15.0">
            <children>
                <TextField fx:id="ownerField" prefWidth="350.0" promptText="Passenger Name" />
                <TextField fx:id="flightField" prefWidth="350.0" promptText="Flight Number" />
                <TextField fx:id="reasonField" prefWidth="350.0" promptText="Reason for Search" />
                <ComboBox fx:id="outcomeCombo" prefWidth="350.0" promptText="Select Outcome" />
                <Button onAction="#saveLogOnAction" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="Save Log" />
            </children>
        </VBox>
        <Button layoutX="520.0" layoutY="350.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>