<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.airportsecurity.Samia.SupervisorGoal7Controller">
    <children>
        <Label layoutX="30.0" layoutY="20.0" text="Goal 7: Baggage Inspection Audit">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <TableView fx:id="baggageTable" layoutX="30.0" layoutY="70.0" prefHeight="300.0" prefWidth="590.0">
            <columns>
                <TableColumn fx:id="ownerCol" prefWidth="180.0" text="Passenger Name" />
                <TableColumn fx:id="flightCol" prefWidth="150.0" text="Flight #" />
                <TableColumn fx:id="outcomeCol" prefWidth="258.0" text="Inspection Outcome" />
            </columns>
        </TableView>
        <Button layoutX="570.0" layoutY="390.0" onAction="#goBackOnAction" text="Back" />
    </children>
</AnchorPane>